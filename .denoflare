{
  "$schema": "https://raw.githubusercontent.com/skymethod/denoflare/v0.7.0/common/config.schema.json",
  "scripts": {
    "love": {
      "path": "bot.ts",
      "localPort": 3031,
      "workersDev": true
    }
  },
  "profiles": {
